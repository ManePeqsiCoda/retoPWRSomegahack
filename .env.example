# ════════════════════════════════════════════════════════════
# CRM PQRSD — Variables de Entorno
# ════════════════════════════════════════════════════════════

# ── IA: OpenRouter ──
OPENROUTER_API_KEY=
NEXT_PUBLIC_OPENROUTER_MODEL=arcee-ai/trinity-large-preview:free
NEXT_PUBLIC_IA_HABILITADA=true

# ── Backend Gateway (DuckClaw) ──
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_ENV=development

# ── SMTP: Gmail (App Password) ──
SMTP_FROM_NAME=Alcaldía de Medellín — Atención al Ciudadano
SMTP_FROM_EMAIL=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_MODE=mock  # 'live' para enviar correos reales | 'mock' para simulación

# ── URL Pública ──
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── MotherDuck: Cloud DuckDB (Postgres Wire Protocol) ──
MOTHERDUCK_TOKEN=
MOTHERDUCK_DB=crm_pqrsd
