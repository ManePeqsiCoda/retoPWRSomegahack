# ════════════════════════════════════════════════════════════
# CRM PQRSD — Variables de Entorno
# ════════════════════════════════════════════════════════════

# ── IA: DuckClaw API Gateway (PM2 p. ej. DuckClaw-Gateway) — preferido ──
# Base URL del mismo proceso que sirve /api/v1/agent/.../chat (inferencia PQRSD-Assistant).
DUCKCLAW_GATEWAY_URL=http://127.0.0.1:8000
# Opcional: misma URL expuesta al cliente
# NEXT_PUBLIC_DUCKCLAW_GATEWAY_URL=http://127.0.0.1:8000

# ── IA: OpenRouter (solo fallback si el gateway falla o no está configurado) ──
# Desactivar fallback: CRM_IA_OPENROUTER_FALLBACK=false
# CRM_IA_OPENROUTER_FALLBACK=true
OPENROUTER_API_KEY=
NEXT_PUBLIC_OPENROUTER_MODEL=arcee-ai/trinity-large-preview:free
NEXT_PUBLIC_IA_HABILITADA=true

# ── Backend Gateway (DuckClaw) — alias para el CRM ──
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_ENV=development

# ── SMTP: Gmail (App Password) ──
SMTP_FROM_NAME=Alcaldía de Medellín — Atención al Ciudadano
SMTP_FROM_EMAIL=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_MODE=mock  # 'live' para enviar correos reales | 'mock' para simulación

# ── URL Pública ──
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── DuckDB local (misma bóveda que PQRSD-Assistant en DuckClaw) ──
# Copiar desde la raíz del monorepo (.env): ruta relativa al repo o absoluta.
# Next resuelve rutas relativas con DUCKCLAW_REPO_ROOT (o por defecto ../../ desde external/retoPWRSomegahack).
DUCKCLAW_PQRSD_ASSISTANT_DB_PATH=db/private/1726618406/pqrsd-assistantdb1.duckdb
# Opcional: raíz del repo Duckclaw si ejecutas `npm run dev` fuera de external/retoPWRSomegahack
# DUCKCLAW_REPO_ROOT=/ruta/al/duckclaw

# Alias opcional (retrocompatibilidad); si falta DUCKCLAW_PQRSD_ASSISTANT_DB_PATH se usa CRM_DUCKDB_PATH
# CRM_DUCKDB_PATH=

# user_id de bóveda para POST /api/v1/db/read|write (carpeta db/private/<id>/)
# CRM_VAULT_USER_ID=1726618406
# CRM_TENANT_ID=PQRS
# Solo desarrollo: DDL + seed desde mock si la tabla está vacía (requiere Redis + db-writer)
# CRM_AUTO_BOOTSTRAP=false
