# CRM PQRSD · Alcaldía de Medellín
# Copia este archivo como .env.local y configura los valores

# URL del backend CRM (FastAPI + DuckDB) — bandeja / tickets (futuro)
# Local (Tailscale): https://mac-mini-de-juan.tailc85db0.ts.net
# Producción: https://api.crm-pqrsd.medellin.gov.co
NEXT_PUBLIC_API_URL=https://mac-mini-de-juan.tailc85db0.ts.net

# DuckClaw API Gateway — panel «Asistente IA» (worker PQRSD-Assistant)
# Preferido en servidor (no se expone al bundle del cliente)
DUCKCLAW_GATEWAY_URL=http://127.0.0.1:8000
# Opcional: misma URL pública para validar en el cliente que la IA está configurada
NEXT_PUBLIC_DUCKCLAW_GATEWAY_URL=http://127.0.0.1:8000

# Debe coincidir con un user_id autorizado en el gateway (tenant PQRS) o con DUCKCLAW_OWNER_ID.
DUCKCLAW_GATEWAY_USER_ID_OVERRIDE=1726618406

# Activar panel de IA (requiere URL de gateway arriba)
NEXT_PUBLIC_IA_HABILITADA=true

# Legacy — OpenRouter (ya no usa el panel si DuckClaw responde; se puede eliminar)
# OPENROUTER_API_KEY=sk-or-REEMPLAZA_CON_TU_CLAVE
# NEXT_PUBLIC_OPENROUTER_MODEL=arcee-ai/trinity-large-preview:free

# Entorno de ejecución
NEXT_PUBLIC_ENV=development